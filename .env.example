# Consumed by `docker compose` (Compose reads .env from this directory) at BUILD time.
# NEXT_PUBLIC_* values are inlined into the frontend browser bundle, so they must be set
# here before `docker compose up --build`. Without NEXT_PUBLIC_INSFORGE_URL, in-browser
# login fails with "network request failed".
#
# Note: the host dev loop (`cd frontend && npm run dev`) uses frontend/.env instead.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_INSFORGE_URL=
# Optional. Leave blank unless your InsForge project requires it. Never put a
# privileged/admin key here — NEXT_PUBLIC_* ships to the browser.
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Backend (only needed if you want the *containerised* backend to call the LLM; the
# host dev loop uses backend/.env). Leave blank otherwise.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
