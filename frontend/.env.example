# Backend (FastAPI) base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# InsForge (auth + history). URL is your project's base URL.
# The anon key is optional — the base URL identifies the project and authenticated
# operations use the logged-in user's session. Set it if your project requires it.
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
